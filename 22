Algoritmo ArregloPorTeclado
	Definir num, i Como Entero
	Dimension num[5]
	
	// Primer bucle: Para guardar los datos ingresados por el usuario
	Para i <- 1 Hasta 5 Con Paso 1 Hacer
		Escribir "Ingrese el número para la posición ", i, ":"
		Leer num[i]
	FinPara
	
	Escribir "Los números ingresados son:"
	
	// Segundo bucle: Para mostrar los datos guardados (igual al de tu imagen)
	Para i <- 1 Hasta 5 Con Paso 1 Hacer
		Escribir num[i]
	FinPara
	
FinAlgoritmo
