Algoritmo TablaMultiplicar
    Definir tabla, i, resultado Como Entero
    
    Escribir "Ingrese el número de la tabla que desea calcular:"
    Leer tabla
    
    Escribir "Tabla del ", tabla, ":"
    
    // El bucle "Para" ejecuta las instrucciones una cantidad fija de veces
    Para i <- 1 Hasta 10 Con Paso 1 Hacer
        resultado <- tabla * i
        Escribir tabla, " x ", i, " = ", resultado
    FinPara
    
FinAlgoritmo
